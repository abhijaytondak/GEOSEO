    {"type":"text","id":"filt_code","x":842,"y":342,"width":470,"height":206,"text":"og:image + twitter:image  (first)\nfor each <img> tag:\n  if (w<64 || h<64)            → skip  // tiny icons\n  if (/sprite|icon|avatar|\n      placeholder|hamburger/)  → skip  // junk\n  src = largestFromSrcset(set) ?? src ?? data-src\n  if (/^data:/.test(src))      → skip\n  url = new URL(decode(src), base)  // &amp;→& , absolute\n  push(url)                    // deduped via Set\nMAX_IMAGES = 60","originalText":"og:image + twitter:image  (first)\nfor each <img> tag:\n  if (w<64 || h<64)            → skip  // tiny icons\n  if (/sprite|icon|avatar|\n      placeholder|hamburger/)  → skip  // junk\n  src = largestFromSrcset(set) ?? src ?? data-src\n  if (/^data:/.test(src))      → skip\n  url = new URL(decode(src), base)  // &amp;→& , absolute\n  push(url)                    // deduped via Set\nMAX_IMAGES = 60","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":101072,"version":1,"versionNonce":1,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

