# GEOSEO API — Railway environment template
# Copy real values from your local apps/api/.env (gitignored). Set these on the
# Railway service (Variables tab, or `railway variables --set "KEY=value"`).
# Do NOT set PORT — Railway injects it and the API reads $PORT automatically.

# ---- Core (required for a production host) ----
GEOSEO_MODE=production            # fail-closed: auth CANNOT be disabled in production
API_AUTH_REQUIRED=true            # required; boot aborts if production + auth disabled
DEV_API_TOKEN=                    # bearer secret the web BFF injects (until Clerk JWT verify lands)
WEB_ORIGIN=https://geoseo-tau.vercel.app   # the web origin, for CORS (your Vercel/custom domain)

# ---- Persistence ----
DATABASE_URL=                     # Supabase Postgres connection string (unset ⇒ in-memory, non-durable)
REDIS_URL=                        # Upstash Redis (BullMQ durable jobs); unset ⇒ in-memory queue

# ---- LLM (content/page generation) ----
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- Integration seams (OPTIONAL — set to flip a capability from demo→live) ----
# Keyword research (DataForSEO Labs):
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# CRM sync (HubSpot private-app token):
HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_PORTAL_ID=
# Search Console (real rankings/impressions for an owned, verified property):
GSC_SERVICE_ACCOUNT_JSON=         # the full service-account JSON (one line)
GSC_SITE_URL=                     # e.g. https://yourcustomer.com/  (must match the GSC property)
# Image generation (OpenAI-compatible images API):
IMAGE_GEN_API_KEY=
# IMAGE_GEN_BASE_URL=https://api.openai.com/v1
# IMAGE_GEN_MODEL=gpt-image-1
# CMS publishing — set ONE provider's vars (auto-detected; CMS_PROVIDER forces choice):
# WordPress:
# WORDPRESS_BASE_URL=
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=
# Webflow:
# WEBFLOW_API_TOKEN=
# WEBFLOW_COLLECTION_ID=
# WEBFLOW_SITE_HOST=
# Shopify:
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ACCESS_TOKEN=
# Public host used in published page URLs / llms.txt / sitemap (defaults to Brand Memory domain):
# PUBLIC_SITE_HOST=
